<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
<script>
gsap.registerPlugin(ScrollTrigger);

/* cursor */
(function(){
  const c=document.querySelector('.cur');let x=0,y=0,cx=0,cy=0;
  addEventListener('mousemove',e=>{x=e.clientX;y=e.clientY});
  (function f(){cx+=(x-cx)*.2;cy+=(y-cy)*.2;c.style.left=cx+'px';c.style.top=cy+'px';requestAnimationFrame(f)})();
  document.querySelectorAll('a,.fcard,.burger,.btn').forEach(el=>{
    el.addEventListener('mouseenter',()=>{c.style.width='56px';c.style.height='56px';c.style.background='rgba(255,255,255,.1)'});
    el.addEventListener('mouseleave',()=>{c.style.width='34px';c.style.height='34px';c.style.background='transparent'});
  });
})();

/* loader */
(function(){
  const ln=document.getElementById('loadName');
  "SAMPLE".split('').forEach(ch=>{const s=document.createElement('span');s.textContent=ch;ln.appendChild(s)});
  const tl=gsap.timeline();
  tl.to(ln.querySelectorAll('span'),{y:0,duration:.7,stagger:.05,ease:'power3.out',delay:.2})
    .to('#loadLn',{width:280,duration:.7,ease:'power2.inOut'},'-=.3')
    .to(ln.querySelectorAll('span'),{y:'-110%',duration:.55,stagger:.04,ease:'power3.in'})
    .to('#load',{yPercent:-100,duration:.8,ease:'power4.inOut'},'-=.2')
    .set('#load',{display:'none'})
    .add(heroIn,'-=.4');
})();

function heroIn(){
  gsap.to('.hero-c h1 .l i',{y:0,duration:1,stagger:.13,ease:'power4.out'});
  gsap.to('.hero-c .label',{opacity:.85,duration:.9,delay:.2});
  gsap.to('.hero-c .sub',{opacity:1,duration:1,delay:.6});
  gsap.to('.hero-strip',{opacity:1,y:0,duration:1.2,delay:.4,ease:'power3.out'});
  gsap.to('.hero-num',{opacity:1,duration:1.2,delay:.6});
}

/* header */
const hd=document.getElementById('hd');
ScrollTrigger.create({trigger:'#hero',start:'bottom 80px',
  onEnter:()=>{hd.classList.add('scrolled');hd.classList.remove('hero-mode')},
  onLeaveBack:()=>{hd.classList.remove('scrolled');hd.classList.add('hero-mode')}});

/* reveals & masks */
gsap.utils.toArray('.reveal').forEach(el=>{
  gsap.to(el,{opacity:1,y:0,duration:1,ease:'power3.out',scrollTrigger:{trigger:el,start:'top 86%'}});
});
gsap.utils.toArray('.mask').forEach(el=>{
  gsap.to(el,{clipPath:'inset(0 0 0% 0)',duration:1.3,ease:'power4.out',scrollTrigger:{trigger:el,start:'top 82%'}});
});

/* parallax */
gsap.to('#hero .bg',{yPercent:16,ease:'none',scrollTrigger:{trigger:'#hero',start:'top top',end:'bottom top',scrub:true}});
gsap.to('.hero-strip',{yPercent:-22,ease:'none',scrollTrigger:{trigger:'#hero',start:'top top',end:'bottom top',scrub:true}});
gsap.to('.concept-photo .fill',{yPercent:-10,ease:'none',scrollTrigger:{trigger:'#concept',start:'top bottom',end:'bottom top',scrub:true}});
gsap.to('.concept-card',{y:-40,ease:'none',scrollTrigger:{trigger:'#concept',start:'top bottom',end:'bottom top',scrub:true}});
gsap.to('.coun-photos .b',{y:-30,ease:'none',scrollTrigger:{trigger:'#counseling',start:'top bottom',end:'bottom top',scrub:true}});
gsap.to('#cta .ghost',{y:-30,ease:'none',scrollTrigger:{trigger:'#cta',start:'top bottom',end:'bottom top',scrub:true}});

/* feature stagger：CSSの千鳥translateYを保持したまま、opacityと微小な上げだけ動かす */
gsap.utils.toArray('.fcard').forEach((card)=>{
  gsap.set(card,{opacity:0});
  ScrollTrigger.create({trigger:card,start:'top 92%',once:true,
    onEnter:()=>gsap.to(card,{opacity:1,duration:1,ease:'power2.out'})});
});

/* marquee */
(function(){const t=document.getElementById('mq');t.innerHTML+=t.innerHTML;gsap.to(t,{xPercent:-50,duration:18,ease:'none',repeat:-1});})();

/* ===== PAGE FLIP ===== */
(function(){
  const pages=gsap.utils.toArray('.flip-page'); // [3,2,1,0]
  const total=pages.length;
  // 表示順：data-i 0が一番上。上から順にめくる
  const ordered=pages.slice().sort((a,b)=>a.dataset.i-b.dataset.i); // [0,1,2,3]
  ScrollTrigger.create({
    trigger:'.flip-sec',start:'top top',end:'bottom bottom',scrub:.6,
    onUpdate:self=>{
      const p=self.progress*(total-1); // 0..3
      ordered.forEach((page,i)=>{
        let rot=0,sh=1;
        if(i<p-0 && i<total-1){
          // めくり進行
          const local=Math.min(Math.max(p-i,0),1);
          rot=-local*170; // -170度まで開く
          sh=1-local*0.15;
          page.style.zIndex=10+i; // めくった紙は上へ重なる感
        } else {
          page.style.zIndex= total-i;
        }
        page.style.transform=`rotateY(${rot}deg) scale(${sh})`;
        page.style.filter=`brightness(${1-Math.min(Math.max(p-i,0),1)*0.25})`;
      });
    }
  });
})();

/* smooth anchor */
document.querySelectorAll('a[href^="#"]').forEach(a=>{
  a.addEventListener('click',e=>{const id=a.getAttribute('href');if(id==='#')return;
    const t=document.querySelector(id);if(t){e.preventDefault();scrollTo({top:t.offsetTop,behavior:'smooth'})}});
});
</script>
